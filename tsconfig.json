{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    
    // 👇 This is important for Electron + preload bridging
    "types": ["vite/client", "node"]
  },

  // 👇 Add this section — THIS fixes your red errors
  "exclude": [
    "dist",
    "dist-electron",
    "node_modules"
  ],
  
  "include": [
    "src",
    "electron" // ensure your main.ts + preload.ts are included
  ]
}
